{
	"version": 3,
	"routes": [
		{
			"src": "^/_astro/(.*)$",
			"headers": {
				"cache-control": "public, max-age=31536000, immutable"
			},
			"continue": true
		},
		{
			"handle": "filesystem"
		},
		{
			"src": "^\\/_image$",
			"dest": "_render"
		},
		{
			"src": "^\\/admin\\/login\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/admin\\/logout\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/admin\\/projects\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/admin\\/services\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/admin\\/testimonials\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/admin\\/?$",
			"dest": "_render"
		}
	]
}