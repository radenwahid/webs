---
export const prerender = false;
import Layout from '../../layouts/Layout.astro';
import AdminSidebar from '../../components/AdminSidebar.astro';
import { requireAuth } from '../../lib/auth';
import { supabaseAdmin } from '../../lib/supabase';

const authCheck = requireAuth(Astro.request);
if (authCheck) return authCheck;

let message = ''; let isError = false; let uploadedUrl = '';

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const action = form.get('_action') as string;

  if (action === 'create' || action === 'update') {
    // Handle inline image upload if provided
    const imageData = String(form.get('image_data') || '');
    let imageUrl = String(form.get('image_url') || '');

    if (imageData && imageData.startsWith('data:')) {
      const base64 = imageData.split(',')[1];
      const mimeMatch = imageData.match(/data:([^;]+);/);
      const mime = mimeMatch ? mimeMatch[1] : 'image/webp';
      const buffer = Buffer.from(base64, 'base64');
      const filename = `${Date.now()}.webp`;
      const { data: upData, error: upErr } = await supabaseAdmin.storage
        .from('projects').upload(filename, buffer, { contentType: mime, upsert: false });
      if (!upErr && upData) {
        const { data: urlData } = supabaseAdmin.storage.from('projects').getPublicUrl(filename);
        imageUrl = urlData.publicUrl;
      }
    }

    const tagsRaw = String(form.get('tags') || '');
    const tags = tagsRaw.split(',').map((t: string) => t.trim()).filter(Boolean);
    const data = {
      title: form.get('title'), description: form.get('description'),
      image_url: imageUrl, link: form.get('link'), tags,
      visible: form.get('visible') === 'true',
    };
    if (action === 'create') {
      const { error } = await supabaseAdmin.from('projects').insert(data);
      isError = !!error; message = error ? `Error: ${error.message}` : 'Project ditambahkan!';
    } else {
      const { error } = await supabaseAdmin.from('projects').update(data).eq('id', form.get('id'));
      isError = !!error; message = error ? `Error: ${error.message}` : 'Project diupdate!';
    }
  } else if (action === 'delete') {
    const { error } = await supabaseAdmin.from('projects').delete().eq('id', form.get('id'));
    isError = !!error; message = error ? `Error: ${error.message}` : 'Project dihapus.';
  }
}

const { data: projects } = await supabaseAdmin.from('projects').select('*').order('created_at', { ascending: false });
---
<Layout title="Galeri — Admin">
<div class="admin-wrap">
  <AdminSidebar active="projects" />
  <main class="admin-main">
    <h1 class="admin-title">Galeri Project</h1><div style="margin-bottom:1.5rem"><button class="btn btn-primary" id="btnAdd">+ Tambah Project</button></div>
    {message && <div class={`alert ${isError ? 'alert-error' : 'alert-success'}`}>{message}</div>}
    <div class="admin-table-wrap">
      <table class="admin-table">
        <thead><tr><th>Gambar</th><th>Judul</th><th>Link</th><th>Status</th><th>Aksi</th></tr></thead>
        <tbody>
          {projects?.map(p => (
            <tr>
              <td>
                {p.image_url
                  ? <img src={p.image_url} alt={p.title} style="width:60px;height:40px;object-fit:cover;border:2px solid var(--border-color)" />
                  : <span style="color:var(--text-muted)">—</span>}
              </td>
              <td><strong>{p.title}</strong></td>
              <td>{p.link ? <a href={p.link} target="_blank" style="color:var(--accent)">Buka</a> : '—'}</td>
              <td><span class={`badge ${p.visible ? 'badge-on' : 'badge-off'}`}>{p.visible ? 'Aktif' : 'Hidden'}</span></td>
              <td style="display:flex;gap:.5rem;flex-wrap:wrap">
                <button class="btn btn-outline btn-sm edit-btn"
                  data-id={p.id} data-title={p.title} data-desc={p.description || ''}
                  data-image={p.image_url || ''} data-link={p.link || ''}
                  data-tags={p.tags?.join(', ') || ''} data-visible={String(p.visible)}>Edit</button>
                <form method="POST" style="display:inline" onsubmit="return confirm('Hapus?')">
                  <input type="hidden" name="_action" value="delete" />
                  <input type="hidden" name="id" value={p.id} />
                  <button type="submit" class="btn btn-danger btn-sm">Hapus</button>
                </form>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </main>
</div>

<div class="modal-overlay" id="modalOverlay">
  <div class="modal">
    <div class="modal-header">
      <span class="modal-title" id="modalTitle">Tambah Project</span>
      <button class="modal-close" id="btnClose">x</button>
    </div>
    <div class="modal-body">
      <form method="POST" class="admin-form" id="projectForm" enctype="multipart/form-data">
        <input type="hidden" name="_action" id="formAction" value="create" />
        <input type="hidden" name="id" id="formId" />
        <input type="hidden" name="image_data" id="imageData" />
        <input type="hidden" name="image_name" id="imageName" />

        <div class="form-group"><label>Judul Project</label><input name="title" id="fTitle" required /></div>
        <div class="form-group"><label>Deskripsi</label><textarea name="description" id="fDesc"></textarea></div>

        <div class="form-group">
          <label>Upload Gambar (auto-compress ke 150KB)</label>
          <input type="file" id="imageRaw" accept="image/*" />
          <div id="previewWrap" style="display:none;margin-top:.5rem">
            <img id="previewImg" style="max-width:100%;max-height:150px;border:2px solid var(--border-color)" />
            <p id="sizeInfo" class="img-size-info"></p>
          </div>
        </div>

        <div class="form-group">
          <label>Atau URL Gambar (jika sudah ada)</label>
          <input name="image_url" id="fImageUrl" placeholder="https://..." />
        </div>

        <div class="form-group"><label>Link Project</label><input name="link" id="fLink" placeholder="https://..." /></div>
        <div class="form-group"><label>Tags (pisah koma)</label><input name="tags" id="fTags" placeholder="React, Node.js" /></div>
        <div class="form-group">
          <label>Visible</label>
          <select name="visible" id="fVisible"><option value="true">Ya</option><option value="false">Tidak</option></select>
        </div>
        <div class="form-actions">
          <button type="submit" class="btn btn-primary">Simpan</button>
          <button type="button" class="btn btn-outline" id="btnCancel">Batal</button>
        </div>
      </form>
    </div>
  </div>
</div>
</Layout>

<script>
  const overlay = document.getElementById('modalOverlay')!;
  const open = () => overlay.classList.add('open');
  const close = () => { overlay.classList.remove('open'); resetImage(); };

  function resetImage() {
    (document.getElementById('imageData') as HTMLInputElement).value = '';
    (document.getElementById('imageName') as HTMLInputElement).value = '';
    (document.getElementById('imageRaw') as HTMLInputElement).value = '';
    (document.getElementById('previewWrap') as HTMLDivElement).style.display = 'none';
  }

  document.getElementById('btnAdd')?.addEventListener('click', () => {
    document.getElementById('modalTitle')!.textContent = 'Tambah Project';
    (document.getElementById('formAction') as HTMLInputElement).value = 'create';
    (document.getElementById('formId') as HTMLInputElement).value = '';
    (document.getElementById('fTitle') as HTMLInputElement).value = '';
    (document.getElementById('fDesc') as HTMLTextAreaElement).value = '';
    (document.getElementById('fImageUrl') as HTMLInputElement).value = '';
    (document.getElementById('fLink') as HTMLInputElement).value = '';
    (document.getElementById('fTags') as HTMLInputElement).value = '';
    (document.getElementById('fVisible') as HTMLSelectElement).value = 'true';
    resetImage();
    open();
  });

  document.querySelectorAll('.edit-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const d = (btn as HTMLElement).dataset;
      document.getElementById('modalTitle')!.textContent = 'Edit Project';
      (document.getElementById('formAction') as HTMLInputElement).value = 'update';
      (document.getElementById('formId') as HTMLInputElement).value = d.id!;
      (document.getElementById('fTitle') as HTMLInputElement).value = d.title!;
      (document.getElementById('fDesc') as HTMLTextAreaElement).value = d.desc!;
      (document.getElementById('fImageUrl') as HTMLInputElement).value = d.image!;
      (document.getElementById('fLink') as HTMLInputElement).value = d.link!;
      (document.getElementById('fTags') as HTMLInputElement).value = d.tags!;
      (document.getElementById('fVisible') as HTMLSelectElement).value = d.visible!;
      resetImage();
      open();
    });
  });

  document.getElementById('btnClose')?.addEventListener('click', close);
  document.getElementById('btnCancel')?.addEventListener('click', close);
  overlay.addEventListener('click', (e) => { if (e.target === overlay) close(); });

  // Image compression
  const rawInput = document.getElementById('imageRaw') as HTMLInputElement;
  rawInput?.addEventListener('change', () => {
    const file = rawInput.files?.[0];
    if (!file) return;
    (document.getElementById('sizeInfo') as HTMLParagraphElement).textContent = 'Mengompres...';
    (document.getElementById('previewWrap') as HTMLDivElement).style.display = 'block';
    const reader = new FileReader();
    reader.onload = (e) => {
      const img = new Image();
      img.onload = () => {
        let w = img.width, h = img.height;
        if (w > 800) { h = Math.round(h * 800 / w); w = 800; }
        const canvas = document.createElement('canvas');
        canvas.width = w; canvas.height = h;
        canvas.getContext('2d')!.drawImage(img, 0, 0, w, h);
        let lo = 0.1, hi = 0.95, best = '';
        for (let i = 0; i < 10; i++) {
          const mid = (lo + hi) / 2;
          const r = canvas.toDataURL('image/webp', mid);
          const kb = Math.round(r.length * 3 / 4 / 1024);
          if (kb <= 150) { best = r; lo = mid; } else { hi = mid; }
        }
        if (!best) best = canvas.toDataURL('image/webp', lo);
        const kb = Math.round(best.length * 3 / 4 / 1024);
        (document.getElementById('imageData') as HTMLInputElement).value = best;
        (document.getElementById('imageName') as HTMLInputElement).value = file.name.replace(/\.[^.]+$/, '.webp');
        (document.getElementById('previewImg') as HTMLImageElement).src = best;
        (document.getElementById('sizeInfo') as HTMLParagraphElement).textContent = `${w}x${h}px — ${kb} KB (asli: ${Math.round(file.size/1024)} KB)`;
        // Clear manual URL if image uploaded
        (document.getElementById('fImageUrl') as HTMLInputElement).value = '';
      };
      img.src = e.target!.result as string;
    };
    reader.readAsDataURL(file);
  });
</script>

<style>@import '../../styles/admin.css';</style>
