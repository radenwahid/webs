---
export const prerender = false;
import Layout from '../../layouts/Layout.astro';

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const pass = form.get('password');
  if (pass === import.meta.env.ADMIN_PASSWORD) {
    const res = new Response(null, { status: 302, headers: { Location: '/admin' } });
    res.headers.append('Set-Cookie', `admin_auth=1; Path=/; HttpOnly; SameSite=Strict; Max-Age=86400`);
    return res;
  }
}
---
<Layout title="Admin Login — Joki Coding">
  <div class="login-wrap">
    <div class="login-card">
      <div class="login-logo">ADMIN<span>PANEL</span></div>
      <p class="login-sub">Joki Coding by Raden</p>
      <form method="POST" class="login-form">
        <label for="password">Password</label>
        <input type="password" id="password" name="password" required autocomplete="current-password" placeholder="••••••••" />
        <button type="submit" class="btn btn-primary">Masuk →</button>
      </form>
    </div>
  </div>
</Layout>

<style>
.login-wrap {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--bg);
}
.login-card {
  background: var(--bg-card);
  border: 3px solid var(--border-color);
  box-shadow: 8px 8px 0 var(--shadow-color);
  padding: 2.5rem;
  width: 100%;
  max-width: 380px;
}
.login-logo {
  font-family: 'Syne', sans-serif;
  font-weight: 800;
  font-size: 1.5rem;
  text-transform: uppercase;
  margin-bottom: .25rem;
}
.login-logo span { color: var(--accent); }
.login-sub { color: var(--text-muted); font-size: .85rem; margin-bottom: 2rem; }
.login-form { display: flex; flex-direction: column; gap: 1rem; }
.login-form label { font-weight: 700; font-size: .85rem; text-transform: uppercase; letter-spacing: .05em; }
.login-form input {
  padding: .75rem 1rem;
  background: var(--bg);
  border: 2px solid var(--border-color);
  color: var(--text);
  font-family: 'Space Grotesk', sans-serif;
  font-size: 1rem;
  outline: none;
}
.login-form input:focus { border-color: var(--accent); box-shadow: 3px 3px 0 var(--shadow-color); }
.btn { width: 100%; text-align: center; }
</style>
