---
interface Props { active: string; }
const { active } = Astro.props;
---
<aside class="admin-sidebar">
  <div class="sidebar-logo">ADMIN<span>PANEL</span></div>
  <nav class="sidebar-nav">
    <a href="/admin" class={active === 'dashboard' ? 'active' : ''}>📊 Dashboard</a>
    <a href="/admin/services" class={active === 'services' ? 'active' : ''}>⚙️ Services</a>
    <a href="/admin/testimonials" class={active === 'testimonials' ? 'active' : ''}>💬 Testimoni</a>
    <a href="/admin/projects" class={active === 'projects' ? 'active' : ''}>🖼️ Galeri</a>
    <a href="/admin/settings" class={active === 'settings' ? 'active' : ''}>🔑 Settings</a>
    <a href="/" target="_blank">🌐 Lihat Site</a>
    <a href="/admin/logout" class="logout">🚪 Logout</a>
  </nav>
  <div class="sidebar-themes">
    <span class="sidebar-themes-label">🎨 Tema</span>
    <div class="sidebar-theme-btns">
      <button class="sidebar-theme-btn" data-t="dark">
        <span class="theme-swatch" style="background:#7C3AED"></span>Dark
      </button>
      <button class="sidebar-theme-btn" data-t="light">
        <span class="theme-swatch" style="background:#6B21A8"></span>Light
      </button>
      <button class="sidebar-theme-btn" data-t="brutal">
        <span class="theme-swatch" style="background:#FFEE00;border-color:#000"></span>Brutal
      </button>
      <button class="sidebar-theme-btn" data-t="cyber">
        <span class="theme-swatch" style="background:#00FF41"></span>Cyber
      </button>
    </div>
  </div>
</aside>

<script>
  const btns = document.querySelectorAll('.sidebar-theme-btn');
  const html = document.documentElement;
  function syncActive() {
    const cur = html.getAttribute('data-theme') || 'dark';
    btns.forEach(b => b.classList.toggle('active', (b as HTMLElement).dataset.t === cur));
  }
  syncActive();
  btns.forEach(b => {
    b.addEventListener('click', () => {
      const t = (b as HTMLElement).dataset.t!;
      html.setAttribute('data-theme', t);
      localStorage.setItem('theme', t);
      syncActive();
    });
  });
</script>
