---
---
<nav class="navbar" id="navbar">
  <div class="container nav-inner">
    <a href="#hero" class="nav-logo" aria-label="Joki Coding by Raden">
      JOKI<span class="logo-coding">CODING</span>
      <span class="logo-by">by <span class="logo-raden" id="navRaden">RADEN</span></span>
    </a>

    <ul class="nav-links">
      <li><a href="/#services">Services</a></li>
      <li><a href="/#testimonials">Testimoni</a></li>
      <li><a href="/gallery">Galeri</a></li>
      <li><a href="/#contact">Kontak</a></li>
    </ul>

    <div class="nav-right">
      <!-- Theme Dropdown -->
      <div class="theme-dropdown" id="themeDropdown">
        <button class="theme-btn" id="themeBtn" aria-haspopup="true" aria-expanded="false">
          <span class="theme-dot" id="themeDot"></span>
          <span class="theme-label" id="themeLabel">Dark</span>
          <span class="theme-arrow" id="themeArrow">▾</span>
        </button>
        <ul class="theme-menu" id="themeMenu" role="menu">
          <li role="menuitem" data-theme-val="dark">
            <span class="dot dot-dark"></span> Dark
          </li>
          <li role="menuitem" data-theme-val="light">
            <span class="dot dot-light"></span> Light
          </li>
          <li role="menuitem" data-theme-val="brutal">
            <span class="dot dot-brutal"></span> Brutal
          </li>
          <li role="menuitem" data-theme-val="cyber">
            <span class="dot dot-cyber"></span> Cyber
          </li>
        </ul>
      </div>

      <!-- Lang Toggle -->
      <button class="lang-btn" id="langBtn" aria-label="Switch language">ID</button>

      <button class="nav-hamburger" id="hamburger" aria-label="Menu" aria-expanded="false">
        <span class="ham-line"></span>
        <span class="ham-line"></span>
        <span class="ham-line"></span>
      </button>
    </div>
  </div>

  <div class="nav-mobile" id="navMobile">
    <a href="/#services">Services</a>
    <a href="/#testimonials">Testimoni</a>
    <a href="/gallery">Galeri</a>
    <a href="/#contact">Kontak</a>
  </div>
</nav>

<script>
  import gsap from 'gsap';

  const html = document.documentElement;

  const themes: Record<string, { label: string; color: string }> = {
    dark:   { label: 'Dark',   color: '#7C3AED' },
    light:  { label: 'Light',  color: '#6B21A8' },
    brutal: { label: 'Brutal', color: '#FFEE00' },
    cyber:  { label: 'Cyber',  color: '#00FF41' },
  };

  // ── Apply theme ──
  function applyTheme(t: string) {
    html.setAttribute('data-theme', t);
    localStorage.setItem('theme', t);
    const dot = document.getElementById('themeDot');
    const label = document.getElementById('themeLabel');
    if (dot) dot.style.background = themes[t]?.color ?? '#fff';
    if (label) label.textContent = themes[t]?.label ?? t;
    // mark active
    document.querySelectorAll('#themeMenu li').forEach(li => {
      li.classList.toggle('active', (li as HTMLElement).dataset.themeVal === t);
    });
  }

  const saved = localStorage.getItem('theme') || 'dark';
  applyTheme(saved);

  // ── Dropdown open/close ──
  const themeBtn = document.getElementById('themeBtn');
  const themeMenu = document.getElementById('themeMenu');
  const themeArrow = document.getElementById('themeArrow');
  let dropOpen = false;

  function openDrop() {
    dropOpen = true;
    themeBtn?.setAttribute('aria-expanded', 'true');
    themeMenu!.style.display = 'flex';
    gsap.fromTo(themeMenu,
      { opacity: 0, y: -8, clipPath: 'inset(0 0 100% 0)' },
      { opacity: 1, y: 0, clipPath: 'inset(0 0 0% 0)', duration: 0.22, ease: 'power2.out' }
    );
    gsap.fromTo('#themeMenu li',
      { opacity: 0, x: -10 },
      { opacity: 1, x: 0, duration: 0.18, stagger: 0.05, ease: 'power2.out' }
    );
    if (themeArrow) themeArrow.style.transform = 'rotate(180deg)';
  }

  function closeDrop() {
    dropOpen = false;
    themeBtn?.setAttribute('aria-expanded', 'false');
    gsap.to(themeMenu, {
      opacity: 0, y: -8, clipPath: 'inset(0 0 100% 0)',
      duration: 0.18, ease: 'power2.in',
      onComplete: () => { themeMenu!.style.display = 'none'; }
    });
    if (themeArrow) themeArrow.style.transform = 'rotate(0deg)';
  }

  themeBtn?.addEventListener('click', (e) => {
    e.stopPropagation();
    dropOpen ? closeDrop() : openDrop();
  });

  document.querySelectorAll('#themeMenu li').forEach(li => {
    li.addEventListener('click', () => {
      applyTheme((li as HTMLElement).dataset.themeVal!);
      closeDrop();
    });
  });

  document.addEventListener('click', () => { if (dropOpen) closeDrop(); });

  // ── Hamburger ──
  const hamburger = document.getElementById('hamburger');
  const navMobile = document.getElementById('navMobile');
  let menuOpen = false;

  hamburger?.addEventListener('click', () => {
    menuOpen = !menuOpen;
    hamburger.setAttribute('aria-expanded', String(menuOpen));
    hamburger.classList.toggle('is-open', menuOpen);
    if (menuOpen) {
      navMobile!.style.display = 'flex';
      gsap.fromTo('#navMobile', { clipPath: 'inset(0 0 100% 0)' }, { clipPath: 'inset(0 0 0% 0)', duration: 0.35, ease: 'power2.out' });
      gsap.fromTo('#navMobile a', { opacity: 0, x: -24 }, { opacity: 1, x: 0, duration: 0.3, stagger: 0.07, ease: 'power2.out' });
    } else {
      gsap.to('#navMobile', { clipPath: 'inset(0 0 100% 0)', duration: 0.25, ease: 'power2.in', onComplete: () => { navMobile!.style.display = 'none'; } });
    }
  });

  document.querySelectorAll('#navMobile a').forEach(link => {
    link.addEventListener('click', () => {
      if (!menuOpen) return;
      menuOpen = false;
      hamburger?.classList.remove('is-open');
      hamburger?.setAttribute('aria-expanded', 'false');
      gsap.to('#navMobile', { clipPath: 'inset(0 0 100% 0)', duration: 0.25, ease: 'power2.in', onComplete: () => { navMobile!.style.display = 'none'; } });
    });
  });

  // ── Sticky ──
  window.addEventListener('scroll', () => {
    const nav = document.getElementById('navbar');
    if (window.scrollY > 20) nav?.classList.add('scrolled');
    else nav?.classList.remove('scrolled');
  });

  // ── Lang toggle ──
  const langBtn = document.getElementById('langBtn');
  let currentLang = localStorage.getItem('lang') || 'id';
  langBtn!.textContent = currentLang.toUpperCase();

  langBtn?.addEventListener('click', () => {
    currentLang = currentLang === 'id' ? 'en' : 'id';
    localStorage.setItem('lang', currentLang);
    langBtn.textContent = currentLang.toUpperCase();
    document.documentElement.setAttribute('lang', currentLang);
    window.dispatchEvent(new Event('langchange'));
  });

  // ── Logo scramble ──
  const navEl = document.getElementById('navRaden');
  const chars = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ';
  const target = 'RADEN';
  function navScramble() {
    if (!navEl) return;
    let iter = 0;
    const max = target.length * 6;
    const iv = setInterval(() => {
      navEl.textContent = target.split('').map((c, i) => i < Math.floor(iter / 6) ? c : chars[Math.floor(Math.random() * chars.length)]).join('');
      iter++;
      if (iter >= max) { clearInterval(iv); navEl.textContent = target; setTimeout(navScramble, 4000); }
    }, 50);
  }
  setTimeout(navScramble, 1200);
</script>

<style>
.navbar {
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 100;
  background-color: var(--bg);
  border-bottom: 3px solid var(--border-color);
  transition: background-color 0.25s ease, border-color 0.25s ease;
}
.navbar.scrolled { box-shadow: 0 4px 0px var(--shadow-color); }

.nav-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0.85rem 1.5rem;
}

.nav-logo {
  font-family: 'Syne', sans-serif;
  font-weight: 800;
  font-size: 1.2rem;
  letter-spacing: -0.02em;
  text-transform: uppercase;
  display: flex;
  flex-direction: column;
  line-height: 1.1;
}
.logo-coding { color: var(--accent); }
.logo-by { font-size: 0.65rem; font-weight: 600; letter-spacing: 0.08em; color: var(--text-muted); text-transform: lowercase; }
.logo-raden { color: var(--accent); font-weight: 800; font-family: 'Courier New', monospace; }

.nav-links { display: flex; gap: 2rem; list-style: none; }
.nav-links a { font-weight: 600; font-size: 0.9rem; text-transform: uppercase; letter-spacing: 0.05em; transition: color 0.2s; }
.nav-links a:hover { color: var(--accent); }

.nav-right { display: flex; align-items: center; gap: 0.75rem; }

/* Lang button */
.lang-btn {
  padding: 0.4rem 0.65rem;
  font-family: 'Space Grotesk', sans-serif;
  font-weight: 800;
  font-size: 0.75rem;
  letter-spacing: 0.08em;
  background: none;
  border: 2px solid var(--border-color);
  box-shadow: 3px 3px 0 var(--shadow-color);
  color: var(--text);
  cursor: pointer;
  transition: transform 0.1s, box-shadow 0.1s, background 0.15s;
}
.lang-btn:hover { background: var(--accent); color: var(--accent-text); transform: translate(-1px,-1px); box-shadow: 4px 4px 0 var(--shadow-color); }

/* ── Theme Dropdown ── */
.theme-dropdown { position: relative; }

.theme-btn {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.4rem 0.85rem;
  font-family: 'Space Grotesk', sans-serif;
  font-weight: 700;
  font-size: 0.8rem;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  background: none;
  border: 2px solid var(--border-color);
  box-shadow: 3px 3px 0 var(--shadow-color);
  color: var(--text);
  cursor: pointer;
  transition: transform 0.1s, box-shadow 0.1s, border-color 0.25s, color 0.25s;
  white-space: nowrap;
}
.theme-btn:hover { transform: translate(-1px,-1px); box-shadow: 4px 4px 0 var(--shadow-color); }

.theme-dot {
  width: 10px; height: 10px;
  border-radius: 50%;
  border: 1.5px solid var(--border-color);
  flex-shrink: 0;
  transition: background 0.2s;
}
.theme-arrow {
  font-size: 0.7rem;
  transition: transform 0.2s ease;
  display: inline-block;
}

.theme-menu {
  display: none;
  position: absolute;
  top: calc(100% + 8px);
  right: 0;
  flex-direction: column;
  min-width: 140px;
  background: var(--bg);
  border: 2px solid var(--border-color);
  box-shadow: 6px 6px 0 var(--shadow-color);
  z-index: 200;
  overflow: hidden;
}
.theme-menu li {
  display: flex;
  align-items: center;
  gap: 0.6rem;
  padding: 0.65rem 1rem;
  font-weight: 600;
  font-size: 0.85rem;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  cursor: pointer;
  transition: background 0.15s, color 0.15s;
  border-bottom: 1px solid var(--border-color);
}
.theme-menu li:last-child { border-bottom: none; }
.theme-menu li:hover, .theme-menu li.active { background: var(--accent); color: var(--accent-text); }
.theme-menu li.active .dot { border-color: var(--accent-text); }

.dot {
  width: 10px; height: 10px;
  border-radius: 50%;
  border: 1.5px solid var(--border-color);
  flex-shrink: 0;
}
.dot-dark   { background: #7C3AED; }
.dot-light  { background: #6B21A8; }
.dot-brutal { background: #FFEE00; border-color: #0A0A0A; }
.dot-cyber  { background: #00FF41; }

/* ── Hamburger ── */
.nav-hamburger {
  display: none;
  flex-direction: column;
  justify-content: center;
  gap: 5px;
  background: none;
  border: 2px solid var(--border-color);
  padding: 0.45rem 0.55rem;
  cursor: pointer;
  width: 40px; height: 40px;
}
.ham-line {
  display: block;
  width: 100%; height: 2px;
  background: var(--text);
  transform-origin: center;
  transition: transform 0.3s ease, opacity 0.3s ease, background 0.2s;
}
.nav-hamburger.is-open .ham-line:nth-child(1) { transform: translateY(7px) rotate(45deg); background: var(--accent); }
.nav-hamburger.is-open .ham-line:nth-child(2) { opacity: 0; transform: scaleX(0); }
.nav-hamburger.is-open .ham-line:nth-child(3) { transform: translateY(-7px) rotate(-45deg); background: var(--accent); }

/* ── Mobile menu ── */
.nav-mobile {
  display: none;
  flex-direction: column;
  border-top: 2px solid var(--border-color);
  clip-path: inset(0 0 100% 0);
}
.nav-mobile a {
  padding: 1rem 1.5rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  border-bottom: 1px solid var(--border-color);
  transition: background 0.15s, color 0.15s;
}
.nav-mobile a:hover { background: var(--accent); color: var(--accent-text); }

@media (max-width: 768px) {
  .nav-links { display: none; }
  .nav-hamburger { display: flex; }
  .theme-label { display: none; }
  .theme-btn { padding: 0.4rem 0.6rem; }
}
</style>
